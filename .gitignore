# -----------------------------------------------------------------------------
# Node.js / Javascript / Monorepo
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
dist/
**/dist/
build/
**/build/
.next/
**/.next/
out/
**/out/

# -----------------------------------------------------------------------------
# Environment & Secret variables (Crucial for Multi-tenant Security)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
.env.sample
**/.env
**/*.env

# -----------------------------------------------------------------------------
# Terraform (Infrastructure IaC)
# -----------------------------------------------------------------------------
# Local .terraform directories
.terraform/
**/.terraform/

# .tfstate files
*.tfstate
*.tfstate.*
**/*.tfstate
**/*.tfstate.*

# Crash log files
crash.log

# Terraform CLI configuration
.terraformrc
terraform.rc

# Ignore all actual tfvars containing secrets
*.tfvars
*.tfvars.json
**/*.tfvars
**/*.tfvars.json

# Ignore terraform plan files
*.tfplan
**/*.tfplan

# ALLOW tfvars templates to be committed
!*.tfvars.example
!terraform.tfvars.example
!**/*.tfvars.example

# Compiled binary files / Terraform locks
.terraform.lock.hcl
**/.terraform.lock.hcl

# -----------------------------------------------------------------------------
# Operating System files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDEs & Editors
# -----------------------------------------------------------------------------
.vscode/
**/.vscode/
.idea/
**/.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

