# -----------------------------------------------------------------------------
# Node.js / Javascript
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
dist/
build/
.next/
out/

# -----------------------------------------------------------------------------
# Environment & Secret variables (Crucial for Multi-tenant Security)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
.env.sample

# -----------------------------------------------------------------------------
# Terraform (Infrastructure IaC)
# -----------------------------------------------------------------------------
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Terraform CLI configuration
.terraformrc
terraform.rc

# Ignore all actual tfvars containing secrets
*.tfvars
*.tfvars.json

# ALLOW tfvars templates to be committed
!*.tfvars.example
!terraform.tfvars.example

# Compiled binary files / Terraform locks
.terraform.lock.hcl

# -----------------------------------------------------------------------------
# Operating System files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDEs & Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/
node_modules/
apps/frontend/node_modules/
