# ─────────────────────────────────────────────────────────────────────────────
# terraform.tfvars.example
#
# Hướng dẫn:
#   1. Copy file này: cp terraform.tfvars.example terraform.tfvars
#   2. Điền các giá trị thực (đánh dấu ← THAY ĐỔI)
#   3. KHÔNG commit terraform.tfvars lên Git (đã có trong .gitignore)
#
# Demo mode (HTTP):
#   - Không cần domain riêng, không cần ACM certificate.
#   - Truy cập trực tiếp qua ALB DNS name (http://...) sau terraform apply.
#
# Thứ tự thực hiện:
#   Bước 1: Chạy deploy-ecr.sh     → lấy ECR Image URIs
#   Bước 2: Điền core_backend_image và realtime_backend_image bên dưới
#   Bước 3: Chạy deploy-infrastructure.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Thông tin chung ──────────────────────────────────────────────────────────
aws_region   = "us-east-1"
environment  = "dev"                 # dev | staging | prod
project_name = "realtime-collab"
account_id   = "655103423690"        # ← THAY: 12 chữ số AWS Account ID của bạn
                                     #   Lấy bằng: aws sts get-caller-identity --query Account

# ── Mạng ─────────────────────────────────────────────────────────────────────
vpc_cidr = "10.0.0.0/16"             # dev: 10.1 | staging: 10.2 | prod: 10.0

# ── ECR Image URIs ────────────────────────────────────────────────────────────
# Điền sau khi chạy deploy-ecr.sh — script sẽ in ra giá trị chính xác.
frontend_image         = "655103423690.dkr.ecr.us-east-1.amazonaws.com/antigroup-frontend:latest"
core_backend_image     = "655103423690.dkr.ecr.us-east-1.amazonaws.com/antigroup-core:latest"
realtime_backend_image = "655103423690.dkr.ecr.us-east-1.amazonaws.com/antigroup-realtime:latest"
# ← THAY: Thay 123456789012 bằng account_id thực của bạn

# ── Cảnh báo qua Email ───────────────────────────────────────────────────────
alert_email = "truongnguyen130824@gmail.com"  # ← THAY
